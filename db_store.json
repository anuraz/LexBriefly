      "id": "case1",
      "name": "Kesavananda Bharati v. State of Kerala",
      "citation": "(1973) 4 SCC 225",
      "court": "Supreme Court of India",
      "subject": "Constitutional Law",
      "bench": "S.M. Sikri (CJI), J.M. Shelat, H.R. Khanna, etc.",
      "date": "April 24, 1973",
      "facts": "The validity of the Kerala Land Reforms Act was challenged. The primary constitutional issue was whether the parliament possessed unlimited authority to amend the Constitution.",
      "issues": "What is the true scope and extent of the amending power of Parliament under Article 368?",
      "ratio": "The Supreme Court, by a thin 7:6 majority, established the legendary 'Basic Structure Doctrine'. Parliament is authorized to modify any and all portions, provided such amendments do not compromise its fundamental core.",
      "takeaways": "Permanently safeguarded essential constitutional principles and protected citizen liberty.",
      "status": "published"
    },
    {
      "id": "case2",
      "name": "Maneka Gandhi v. Union of India",
      "citation": "AIR 1978 SC 597",
      "court": "Supreme Court of India",
      "subject": "Constitutional Law",
      "bench": "M.H. Beg (CJI), Y.V. Chandrachud, P.N. Bhagwati, etc.",
      "date": "January 25, 1978",
      "facts": "The petitioner's passport was impounded by the passport authorities under Section 10(3)(c) of the Passports Act in public interest.",
      "issues": "Does Article 21 require procedural fairness ('due process')? Is right to travel a personal liberty?",
      "ratio": "Interpreted Article 21 expansively. Procedure established by law must be 'just, fair, and reasonable'.",
      "takeaways": "Merged Articles 14, 19, and 21 into the 'Golden Triangle'.",
      "status": "published"
    }
